{
  "name": "telebox",
  "version": "0.2.8",
  "description": "TeleBox - A Telegram bot framework built on mtcute (TypeScript)",
  "scripts": {
    "start": "node scripts/run-tsx.cjs ./src/index.ts",
    "tpm": "node scripts/run-tsx.cjs ./src/plugin/tpm.ts",
    "dev": "NODE_ENV=development node scripts/run-tsx.cjs ./src/index.ts",
    "pm2:start": "pm2 start scripts/pm2-launcher.sh --name telebox-mtcute --cwd . --interpreter bash --time --max-memory-restart 512M --restart-delay 5000",
    "pm2:stop": "pm2 stop telebox-mtcute",
    "pm2:restart": "pm2 restart telebox-mtcute --update-env"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TiaraBasori/TeleBox_mtcute.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "mtcute",
    "telebox",
    "typescript"
  ],
  "author": "TiaraBasori <mintabyss233@gmail.com>",
  "license": "LGPL-2.1-only",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TiaraBasori/TeleBox_mtcute/issues"
  },
  "homepage": "https://github.com/TiaraBasori/TeleBox_mtcute#readme",
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "glob": "^11.0.0",
    "smartcrop-sharp": {
      "sharp": "$sharp"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mtcute/dispatcher": "^0.30.1",
    "@mtcute/node": "^0.30.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "archiver": "^7.0.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "big-integer": "^1.6.52",
    "canvas": "^3.2.1",
    "cheerio": "^1.2.0",
    "cron": "^4.3.3",
    "dayjs": "^1.11.21",
    "dotenv": "^17.2.2",
    "emoji-db": "^16.0.1",
    "jimp": "^1.6.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.21",
    "lowdb": "^7.0.1",
    "lru-cache": "^6.0.0",
    "modern-gif": "^2.0.4",
    "node-schedule": "^2.1.1",
    "opencc-js": "^1.0.5",
    "p-limit": "^7.2.0",
    "qrcode-terminal": "^0.12.0",
    "runes": "^0.4.3",
    "sharp": "^0.34.3",
    "smartcrop-sharp": "^2.0.8",
    "ssh2": "^1.15.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/big-integer": "^0.0.30",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cron": "^2.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.20",
    "@types/lowdb": "^1.0.15",
    "@types/node": "^24.3.0",
    "@types/opencc-js": "^1.0.3",
    "@types/qrcode-terminal": "^0.12.2",
    "vitest": "^4.1.8"
  }
}
